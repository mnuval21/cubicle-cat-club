{
  "name": "@cubicle-cat-club/server",
  "version": "0.1.0",
  "description": "WebSocket server for Cubicle Cat Club — watches agent sessions and broadcasts events",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./src/adapters/types.ts"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts --mock",
    "build": "tsc",
    "start": "node dist/cli.js",
    "mock": "tsx src/cli.ts --mock",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cubicle-cat-club/shared": "*",
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "chokidar": "^3.6.0",
    "open": "^10.2.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.11",
    "tsx": "^4.16.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
